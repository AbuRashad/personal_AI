generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum GoalPeriod {
  ANNUAL
  QUARTERLY
  MONTHLY
  WEEKLY
  DAILY
}

enum GoalStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum MilestoneStatus {
  PLANNED
  ACTIVE
  COMPLETED
  MISSED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IdeaStatus {
  INBOX
  EVALUATING
  PLANNED
  PARKED
  REJECTED
}

enum NoteStatus {
  ACTIVE
  ARCHIVED
}

enum DocumentStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum ChunkSourceType {
  DOCUMENT
  NOTE
  MEMORY
}

enum MemoryType {
  PREFERENCE
  FACT
  DECISION
  CONTEXT
  SUMMARY
}

enum ReviewType {
  DAILY
  WEEKLY
  MONTHLY
}

enum ReviewStatus {
  DRAFT
  SUBMITTED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum RecommendationType {
  PRIORITIZATION
  DAILY_PLAN
  WEEKLY_PLAN
  REVIEW_INSIGHT
  IDEA_SCORING
}

enum RecommendationStatus {
  PROPOSED
  ACCEPTED
  DISMISSED
  APPLIED
}

enum NotificationType {
  SYSTEM
  REMINDER
  REVIEW_PROMPT
  AI_NUDGE
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

model User {
  id                     String                   @id @default(cuid())
  email                  String                   @unique
  passwordHash           String?
  displayName            String?
  timezone               String?                  @default("UTC")
  locale                 String?                  @default("en")
  role                   UserRole                 @default(USER)
  status                 UserStatus               @default(ACTIVE)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  authAccounts           AuthAccount[]
  authSessions           AuthSession[]
  goals                  Goal[]
  projects               Project[]
  milestones             Milestone[]
  tasks                  Task[]
  ideas                  Idea[]
  notes                  Note[]
  documents              Document[]
  memoryItems            MemoryItem[]
  reviews                Review[]
  aiConversations        AIConversation[]
  aiRecommendations      AIRecommendation[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  analyticsEvents        AnalyticsEvent[]
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  lastSeenAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id          String      @id @default(cuid())
  ownerId     String
  parentId    String?
  title       String
  description String?
  period      GoalPeriod
  status      GoalStatus  @default(DRAFT)
  priority    Int?        @default(0)
  progress    Float?      @default(0)
  targetDate  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent      Goal?       @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Goal[]      @relation("GoalHierarchy")
  projects    Project[]
  tasks       Task[]
  ideas       Idea[]

  @@index([ownerId, status])
  @@index([parentId])
}

model Project {
  id           String        @id @default(cuid())
  ownerId      String
  goalId       String?
  title        String
  description  String?
  status       ProjectStatus @default(PLANNED)
  priority     Int?          @default(0)
  startDate    DateTime?
  targetDate   DateTime?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  goal         Goal?         @relation(fields: [goalId], references: [id], onDelete: SetNull)
  milestones   Milestone[]
  tasks        Task[]
  ideas        Idea[]

  @@index([ownerId, status])
  @@index([goalId])
}

model Milestone {
  id           String          @id @default(cuid())
  ownerId      String
  projectId    String
  title        String
  description  String?
  status       MilestoneStatus @default(PLANNED)
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  owner        User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@index([ownerId, status])
  @@index([projectId])
}

model Task {
  id              String           @id @default(cuid())
  ownerId         String
  projectId       String?
  milestoneId     String?
  goalId          String?
  parentTaskId    String?
  title           String
  description     String?
  status          TaskStatus       @default(BACKLOG)
  priority        TaskPriority     @default(MEDIUM)
  estimateMinutes Int?
  dueDate         DateTime?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  milestone       Milestone?       @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  goal            Goal?            @relation(fields: [goalId], references: [id], onDelete: SetNull)
  parentTask      Task?            @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks        Task[]           @relation("TaskHierarchy")
  blocking        TaskDependency[] @relation("BlockingTask")
  blockedBy       TaskDependency[] @relation("BlockedTask")

  @@index([ownerId, status, priority])
  @@index([projectId])
  @@index([milestoneId])
  @@index([goalId])
  @@index([parentTaskId])
}

model TaskDependency {
  id                String   @id @default(cuid())
  blockingTaskId    String
  blockedTaskId     String
  createdAt         DateTime @default(now())
  blockingTask      Task     @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask       Task     @relation("BlockedTask", fields: [blockedTaskId], references: [id], onDelete: Cascade)

  @@unique([blockingTaskId, blockedTaskId])
  @@index([blockedTaskId])
}

model Idea {
  id                String      @id @default(cuid())
  ownerId           String
  goalId            String?
  projectId         String?
  title             String
  summary           String?
  status            IdeaStatus  @default(INBOX)
  impactScore       Int?
  effortScore       Int?
  businessValue     Int?
  priorityScore     Int?
  aiSummary         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  owner             User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  goal              Goal?       @relation(fields: [goalId], references: [id], onDelete: SetNull)
  project           Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  tags              IdeaTag[]

  @@index([ownerId, status])
  @@index([goalId])
  @@index([projectId])
}

model Note {
  id          String      @id @default(cuid())
  ownerId     String
  title       String
  content     String
  status      NoteStatus  @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tags        NoteTag[]

  @@index([ownerId, status])
}

model Document {
  id              String         @id @default(cuid())
  ownerId         String
  title           String
  sourceName      String?
  storageKey      String?
  mimeType        String?
  status          DocumentStatus @default(DRAFT)
  extractedText   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  owner           User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  chunks          DocumentChunk[]
  tags            DocumentTag[]

  @@index([ownerId, status])
}

model DocumentChunk {
  id            String          @id @default(cuid())
  documentId    String
  sourceType    ChunkSourceType @default(DOCUMENT)
  chunkIndex    Int
  content       String
  tokenCount    Int?
  embeddingRef  String?
  createdAt     DateTime        @default(now())
  document      Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([embeddingRef])
}

model MemoryItem {
  id            String      @id @default(cuid())
  ownerId       String
  type          MemoryType
  title         String
  content       String
  source        String?
  relevance     Float?      @default(0)
  lastUsedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, type])
}

model Review {
  id           String       @id @default(cuid())
  ownerId      String
  type         ReviewType
  status       ReviewStatus @default(DRAFT)
  title        String?
  summary      String?
  score        Float?
  periodStart  DateTime
  periodEnd    DateTime
  submittedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, type, periodStart])
}

model AIConversation {
  id            String             @id @default(cuid())
  ownerId       String
  title         String?
  status        ConversationStatus @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  owner         User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  messages      AIMessage[]
  recommendations AIRecommendation[]

  @@index([ownerId, status])
}

model AIMessage {
  id              String      @id @default(cuid())
  conversationId  String
  role            MessageRole
  content         String
  provider        String?
  model           String?
  promptTokens    Int?
  completionTokens Int?
  createdAt       DateTime    @default(now())
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AIRecommendation {
  id              String               @id @default(cuid())
  ownerId         String
  conversationId  String?
  type            RecommendationType
  title           String
  rationale       String?
  targetType      String?
  targetId        String?
  status          RecommendationStatus @default(PROPOSED)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  owner           User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  conversation    AIConversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([ownerId, status])
  @@index([conversationId])
}

model Notification {
  id          String             @id @default(cuid())
  ownerId     String
  type        NotificationType
  title       String
  body        String?
  status      NotificationStatus @default(UNREAD)
  readAt      DateTime?
  scheduledFor DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  owner       User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, status])
  @@index([scheduledFor])
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  emailEnabled          Boolean  @default(true)
  inAppEnabled          Boolean  @default(true)
  dailyReviewReminder   Boolean  @default(true)
  weeklyReviewReminder  Boolean  @default(true)
  aiNudgesEnabled       Boolean  @default(true)
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  ownerId     String
  eventName   String
  eventGroup  String?
  entityType  String?
  entityId    String?
  metadata    Json?
  occurredAt  DateTime @default(now())
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, eventName, occurredAt])
}

model Tag {
  id           String        @id @default(cuid())
  name         String        @unique
  color        String?
  createdAt    DateTime      @default(now())
  ideaLinks    IdeaTag[]
  noteLinks    NoteTag[]
  documentLinks DocumentTag[]
}

model IdeaTag {
  ideaId      String
  tagId       String
  idea        Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ideaId, tagId])
}

model NoteTag {
  noteId      String
  tagId       String
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model DocumentTag {
  documentId  String
  tagId       String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
}
